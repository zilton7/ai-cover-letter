<div class="max-w-md mx-auto mt-10">
  <h2 class="text-2xl font-bold mb-4">Choose a Plan</h2>
  <div class="space-y-4">
    <% STRIPE_PLANS.each do |key, plan| %>
      <div class="p-6 border rounded-lg">
        <h3 class="text-xl font-semibold"><%= plan[:name] %></h3>
        <p class="text-gray-600">$<%= plan[:price] / 100 %>/month</p>
        <%= button_to "Subscribe", checkout_index_path(plan: key),
        class: "mt-4 px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600" ,
        data: { turbo: false }%>
      </div>
    <% end %>
  </div>
</div>