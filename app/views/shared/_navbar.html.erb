<header id="navbar" class="flex flex-row items-center justify-between whitespace-nowrap \
                           order-b border-solid border-b-[#019863] px-4 md:px-10 py-3">
  <!-- Logo and App Name -->
  <div class='flex flex-col items-center md:items-start'>
    <%= link_to root_path, class: 'hover:scale-[0.975] hover:opacity-[0.65] flex flex-col items-center' do %>
      <div class="flex items-center gap-1 text-[#1C160C]">
        <div class="size-6">
          <%= image_tag asset_path('favicon/favicon.svg') %>
        </div>
        <h2 class="text-[#1C160C] text-lg font-bold leading-tight tracking-[-0.015em]"><%= APP_INFO[:app_name]%></h2>
      </div>
      <p class='text-xs italic leading-tight opacity-50'><%= APP_INFO[:motto]%></p>
    <% end %>
  </div>
  <!-- Mobile Menu Toggle (Hamburger Icon) -->
  <div class="md:hidden">
    <button id="mobile-menu-toggle" class="text-[#1C160C] focus:outline-none">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
      </svg>
    </button>
  </div>
  <!-- Navigation Links (Hidden on Mobile by Default) -->
  <div id="mobile-menu" class="hidden md:flex flex-1 justify-end gap-8 flex-col md:flex-row items-center mt-4 md:mt-0">
    <% if user_signed_in? %>
      <%= link_to subscriptions_path do %>
        <div class="flex w-full justify-center">
          <div class="bg-[#F4EFE6] border border-[#F4EFE6] hover:border-[#019863af] p-3 rounded-xl hover:scale-[0.95]">
            <%= turbo_frame_tag "credits_for_user_#{current_user.id}" do %>
              <p class="text-sm">Credits: <span class="font-bold text-[#019863af]"><%= current_user.credits_count %></span></p>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
    <% if current_user.present? %>
      <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-9">
        <%= link_to new_job_path, class: "flex min-w-[84px] max-w-[480px] cursor-pointer items-center justify-center overflow-hidden \
                       rounded-full h-10 px-4 border border-[#F4EFE6] text-[#1C160C] text-sm font-bold leading-normal \
                       tracking-[0.015em] hover:border-[#019863af] hover:scale-[0.95]" do %>
          <span class="truncate">New Job</span>
        <% end %>
        <%= link_to 'Your Jobs', jobs_path, class: 'text-[#1C160C] text-sm font-medium leading-normal hover:border-b \
                                                    hover:border-[#019863af] hover:scale-[0.95]' %>
        <%= link_to 'Subscription', subscriptions_path, class: 'text-[#1C160C] text-sm font-medium leading-normal hover:border-b \
                                                    hover:border-[#019863af] hover:scale-[0.95]' %>
      </div>
    <% end %>
    <% if current_user.present? %>
      <div class="flex gap-2">
        <%= link_to destroy_user_session_path, class: "flex max-w-[480px] cursor-pointer items-center justify-center \
                                                      overflow-hidden rounded-full h-10 bg-[#F4EFE6] text-[#1C160C] \
                                                      gap-2 text-sm font-bold leading-normal tracking-[0.015em] min-w-0 px-2.5\
                                                      border border-[#F4EFE6] hover:border-[#019863af] hover:scale-[0.95]",
                                              data: { turbo_method: :delete, turbo_confirm: 'Logout?' } do %>
          <div class="text-[#1C160C]" data-icon="SignOut" data-size="20px" data-weight="regular">
            <svg xmlns="http://www.w3.org/2000/svg" width="20px" height="20px" fill="currentColor" viewBox="0 0 256 256">
              <path d="M112,216a8,8,0,0,1-8,8H48a16,16,0,0,1-16-16V48A16,16,0,0,1,48,32h56a8,8,0,0,1,0,16H48V208h56A8,8,0,0,1,112,
                    216Zm109.66-93.66-40-40a8,8,0,0,0-11.32,11.32L196.69,120H104a8,8,0,0,0,0,16h92.69l-26.35,26.34a8,8,0,0,0,11.32
                    ,11.32l40-40A8,8,0,0,0,221.66,122.34Z">
              </path>
            </svg>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex gap-2">
        <%= link_to new_user_registration_path, class: "flex min-w-[84px] max-w-[480px] cursor-pointer items-center justify-center \
                                                 overflow-hidden rounded-full h-10 px-4 bg-[#019863] text-[#f8fbfa] hover:scale-[1.05] text-sm \
                                                 font-bold leading-normal tracking-[0.015em]" do %>
          Register
        <% end %>
        <%= link_to new_user_session_path, class: "flex min-w-[84px] max-w-[480px] cursor-pointer items-center justify-center \
                                                 overflow-hidden rounded-full h-10 px-4 bg-[#f8fbfa] text-[#019863] hover:scale-[1.05] text-sm \
                                                 font-bold leading-normal tracking-[0.015em] border border-[#019863]" do %>
          Login
        <% end %>
      </div>
    <% end %>
  </div>
</header>
<!-- JavaScript to Toggle Mobile Menu -->
<script>
  document.getElementById('mobile-menu-toggle').addEventListener('click', function() {
    const mobileMenu = document.getElementById('mobile-menu');
    mobileMenu.classList.toggle('hidden');
  });
</script>