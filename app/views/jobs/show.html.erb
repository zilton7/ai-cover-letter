<%= render TurboModalComponent.new(title: 'All Cover Letters') do %>
  <div class="inline-block relative h-full w-full" data-controller="cover-letter">
    <div class="w-full flex justify-center">
      <%= simple_form_for @job, html: { class:' w-full' } do |f| %>
        <%= f.input :cover_letters, label: false, collection: @job.cover_letters_for_dropdown, selected: @job&.cover_letters&.last&.id,
                                    include_blank: false, input_html: { data: { action: 'change->cover-letter#load' } } %>
      <% end %>
    </div>
    <div data-clipboard-target="source" data-cover-letter-target="content">
      <%= render 'cover_letters/cover_letter', cover_letter: @job&.cover_letters&.last&.body || 'No Cover Letters to show',
                                               user: current_user %>
    </div>
  </div>
<% end %>