<%= turbo_frame_tag "turbo-modal" do %>
  <div id="default-modal" tabindex="-1" aria-hidden="true"
       class="overflow-y-auto overflow-x-hidden fixed inset-0 z-50 flex items-center justify-center w-full h-[full] backdrop-blur-sm backdrop-grayscale backdrop-brightness-50"
       data-controller="turbo-modal" data-turbo-modal-target="modal"
       data-action="turbo:submit-end->turbo-modal#submitEnd keyup@window->turbo-modal#closeWithKeyboard click@window->turbo-modal#closeBackground">
    <div class="relative p-4 w-full max-w-2xl max-h-[90vh]">
      <!-- Modal content -->
      <div class="relative bg-white rounded-lg shadow flex flex-col h-full max-h-[70vh]"
           data-controller="clipboard">
        <!-- Modal header -->
        <div class="flex-none flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600">
          <h3 class="text-xl font-semibold text-gray-900">
            <%= @title %>
          </h3>
          <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-gray-600 dark:hover:text-white"
                  data-modal-hide="default-modal" data-action="turbo-modal#hideModal">
            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
            </svg>
            <span class="sr-only">Close modal</span>
          </button>
        </div>
        <!-- Modal body -->
        <div class="flex-1 overflow-y-scroll p-4 md:p-5 space-y-4 bg-[#edf2f7]" data-clipboard-target="source" data-clipboard-text="Content to copy">
          <%= content %>
        </div>
        <!-- Modal footer -->
        <div class="flex-row flex justify-end items-center p-4 md:p-5 border-t border-gray-200 rounded-b dark:border-gray-600">
          <span data-clipboard-target="copiedIndicator" class="hidden text-green-700 font-semibold mr-2">
            copied
          </span>
          <button data-action="clipboard#copy" title="Copy to clipboard" class="rounded-md px-3.5 py-2.5 bg-[#019863] hover:bg-[#1e5a45] \
                                                                               text-white inline-block font-medium cursor-pointer">
            Copy</button>
        </div>
      </div>
    </div>
  </div>
<% end %>